# Django Configuration
DEBUG=True
DJANGO_SECRET_KEY=dev-secret-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
DATABASE_NAME=ownfirebase
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Maintenance DB role (optional): a Postgres role created with BYPASSRLS,
# used only by cross-tenant background jobs (e.g. cleanup_pending_uploads)
# that must query across all projects at once. Leave unset to disable —
# those jobs then no-op under Row-Level Security instead of erroring.
# MAINTENANCE_DATABASE_USER=ownfirebase_maintenance
# MAINTENANCE_DATABASE_PASSWORD=

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT / Security
JWT_SIGNING_KEY=dev-jwt-key-change-in-production

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Email (for user verification, password reset)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# S3 / MinIO (optional, for file storage)
USE_S3=False
AWS_STORAGE_BUCKET_NAME=ownfirebase
AWS_S3_REGION_NAME=us-east-1
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_S3_USE_SSL=False

# Celery & Celery Beat
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO

# Stripe billing (billing/stripe_service.py)
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# STRIPE_API_BASE=http://localhost:12111  # point at a local stripe-mock instance for dev/tests
STRIPE_PRICE_STARTER=price_your_starter_price_id
STRIPE_PRICE_PRO=price_your_pro_price_id
STRIPE_PRICE_ENTERPRISE=price_your_enterprise_price_id
